<!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link rel="stylesheet" href="css/register-login.css">
        <title>Create List | TODO List</title>
    </head>
    <body>
        <div class="container">
            <div class="reg-block">
                <h1>Create list</h1>
                <div class="register-box">
                    <form action="/todo/create" method="POST">
                        <label for="title">Title:</label><br>
                        <input type="text" id="title" name="title"><br>
                        <label for="createdby">Users:</label><br>
                        <input type="text" id="createdby" name="createdby"><br>
                        <input type="submit" value="Add">
                        <br><small>By submitting this form, the new todo list will be created</small>
                    </form>
                    <small>Go <a href="/todo">back</a></small>
                </div>
            </div>
        </div>
    </body>
</html>