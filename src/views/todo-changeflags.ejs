<!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link rel="stylesheet" href="css/register-login.css">
        <title>Change Flags | TODO List</title>
    </head>
    <body>
        <div class="container">
            <div class="reg-block">
                <h1>Change flags in this list</h1>
                <div class="register-box">
                    <form action="/todo/task/<%= list.id %>/changeflag" method="POST">
                        <input type="radio" id="flag1" name="flags" value="Active">
                        <label for="age1">Active</label><br>
                        <input type="radio" id="flag2" name="flags" value="Done">
                        <label for="age2">Done</label><br>  
                        <input type="radio" id="flag3" name="flags" value="Remove">
                        <label for="age3">Remove</label><br><br>
                        <input type="submit" value="Change Flag">
                        <br><small>Adding a user allows him to manage all tasks in the list.</small>
                    </form>
                    <small>Go <a href="/todo">back</a></small>
                </div>
            </div>
        </div>
    </body>
</html>